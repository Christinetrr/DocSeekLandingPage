# Base URL of the DocSeek web app (no trailing path). Primary CTAs link here.
VITE_DOCSEEK_APP_URL=http://localhost:5173

# Optional: full URL to the quick demo screen recording (.mov / .mp4).
# GitHub rejects files > 100 MB — keep public/quick_demo.mov untracked locally and
# host the asset on a CDN, S3, or GitHub Release, then set this in production.
# VITE_QUICK_DEMO_VIDEO_URL=https://example.com/path/quick_demo.mov
